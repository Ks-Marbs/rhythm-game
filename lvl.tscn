[sub_resource type="GDScript" id="GDScript_kfp6p"]
script/source = "extends Sprite2D
var notes:= []
signal end
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.
 
func easer(start,end,ease,k):
	match ease:
			\"line\":
				return lerp(start, end, k)
			\"sin\":
				return lerp(start, end, -(cos(PI * k) - 1) / 2)
			\"in-sin\":
				return lerp(start, end, 1 - cos(PI * k / 2))
			\"out-sin\":
				return lerp(start, end, sin(PI * k / 2))
			\"exp\":
				if k < 0.5: return lerp(start, end, pow(2.0, 20.0 * k - 10.0) / 2.0)
				else: return lerp(start, end, 1.0 - pow(2.0, -20.0 * k + 10.0) / 2.0)
			\"in-exp\":
				return lerp(start, end, pow(2.0, 10.0 * k - 10.0))
			\"out-exp\":
				return lerp(start, end, 1.0 - pow(2.0, -10.0 * k))
			\"inst\":
				return end

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _physics_process(delta: float) -> void:
	if Global.dis:
		for note in notes:
			match note[0]:
				\"r\":
					if Global.plays*5.0*Global.bpm/12.0 > note[3]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[3]+note[4])*25+(Global.offset) :
						rotate_camera(note[1],note[2],note[3],note[4],note[5])
				\"rs\":
					if Global.plays*5.0*Global.bpm/12.0 > note[3]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[3]+note[4])*25+(Global.offset) :
						rotate_sq(note[1],note[2],note[3],note[4],note[5])
				\"p\":
					if Global.plays*5.0*Global.bpm/12.0 > note[5]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[5]+note[6])*25+(Global.offset) :
						position_camera(note[1],note[2],note[3],note[4],note[5],note[6],note[7])
				\"ps\":
					if Global.plays*5.0*Global.bpm/12.0 > note[5]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[5]+note[6])*25+(Global.offset) :
						position_sq(note[1],note[2],note[3],note[4],note[5],note[6],note[7])
				\"z\":
					if Global.plays*5.0*Global.bpm/12.0 > note[5]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[5]+note[6])*25+(Global.offset) :
						zoom_camera(note[1],note[2],note[3],note[4],note[5],note[6],note[7])
				\"g\":
					if Global.plays*5.0*Global.bpm/12.0 > note[3]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[3]+note[4])*25+(Global.offset) :
						glitch(note[1],note[2],note[3],note[4],note[5])
				\"n\":
					if Global.plays*5.0*Global.bpm/12.0 > note[3]*25+(Global.offset) and\\
					 Global.plays*5.0*Global.bpm/12.0 < (note[3]+note[4])*25+(Global.offset) :
						negate(note[1],note[2],note[3],note[4],note[5])
				\"e\":
					if Global.plays*5.0*Global.bpm/12.0 > note[1]*25+(Global.offset):
						emit_signal(\"end\")
	else:
		for note in notes:
			match note[0]:
				\"e\":
					if Global.plays*5.0*Global.bpm/12.0 > note[1]*25+(Global.offset):
						emit_signal(\"end\")
	pass
func _on_node_2d_lod() -> void:
	Global.rady += 1
	pass

func rotate_camera(start,end:float,ts:float,t:float,ease):
	start=float(start)
	end=float(end)
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.ro = easer(start,end,ease,k)


func glitch(start,end:float,ts:float,t:float,ease):
	start=float(start)
	end=float(end)
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.glitch = easer(start,end,ease,k)


func negate(start,end:float,ts:float,t:float,ease):
	start=float(start)
	end=float(end)
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.negate = easer(start,end,ease,k)


func rotate_sq(start,end:float,ts:float,t:float,ease):
	start=float(start)
	end=float(end)
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.rs = easer(start,end,ease,k)

func position_sq(s1,s2,e1,e2,ts:float,t:float,ease):
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.pos = easer(Vector2(s1,s2),Vector2(e1,e2),ease,k)


func position_camera(s1,s2,e1,e2,ts:float,t:float,ease):
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.po = easer(Vector2(s1,s2),Vector2(e1,e2),ease,k)


func zoom_camera(s1,s2,e1,e2,ts:float,t:float,ease):
	var blue = Global.plays*5.0*Global.bpm/12.0
	ts = ts*25.0+(Global.offset-4)
	t = t*25
	if (blue > ts-5) and (blue < ts+t):
		var k = ((blue-ts)/t)
		Global.zo = easer(Vector2(s1,s2),Vector2(e1,e2),ease,k)
"

